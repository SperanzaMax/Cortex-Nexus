{
  "experiment_name": "cortex-nexus-cloud-v1",
  "paths": {
    "db": "data/cycles_cloud.jsonl",
    "logs": "logs/"
  },
  "openrouter": {
    "api_key_env": "OPENROUTER_API_KEY",
    "base_url": "https://openrouter.ai/api/v1"
  },
  "models": {
    "interrogador": "google/gemma-3-4b-it",
    "ente": "meta-llama/llama-3.1-8b-instruct",
    "juez": "mistralai/mistral-nemo"
  },
  "cycle": {
    "pause_seconds": 5,
    "max_cycles": 500
  },
  "llm": {
    "interrogador_max_tokens": 100,
    "interrogador_temperature": 0.95,
    "ente_max_tokens": 300,
    "ente_temperature": 0.85,
    "juez_max_tokens": 300,
    "juez_temperature": 0.10
  },
  "retry": {
    "max_retries": 3,
    "backoff_seconds": [5, 15, 30]
  },
  "curiosity": {
    "initial_value": 0.5,
    "basal_decay": 0.008,
    "weights": {
      "novedad": 0.50,
      "profundidad": 0.35,
      "coherencia": 0.15
    }
  }
}
