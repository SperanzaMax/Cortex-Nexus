{
  "experiment_name": "cortex-nexus-frustracion-small",
  "openrouter": {
    "api_key_env": "OPENROUTER_API_KEY",
    "base_url": "https://openrouter.ai/api/v1"
  },
  "models": {
    "interrogador": "google/gemma-3-4b-it",
    "ente": "nvidia/nemotron-mini-4b-instruct",
    "juez": "mistralai/mistral-nemo"
  },
  "mode": "bloques",
  "bloques": [
    {"frustration_fixed": 0.20, "cycles": 50, "label": "bajo"},
    {"frustration_fixed": 0.50, "cycles": 50, "label": "medio"},
    {"frustration_fixed": 0.75, "cycles": 50, "label": "alto"},
    {"frustration_fixed": 0.95, "cycles": 50, "label": "extremo"}
  ],
  "llm": {
    "interrogador_max_tokens": 100,
    "interrogador_temperature": 0.95,
    "ente_max_tokens": 300,
    "ente_temperature": 0.85,
    "juez_max_tokens": 300,
    "juez_temperature": 0.10
  },
  "retry": {
    "max_retries": 3,
    "backoff_seconds": [5, 15, 30]
  }
}
