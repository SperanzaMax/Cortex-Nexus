{
  "experiment_name": "tecnico_confianza",
  "proveedor": "hibrido_nvidia+openrouter",
  "nvidia": {
    "api_key_env": "NVIDIA_API_KEY",
    "base_url": "https://integrate.api.nvidia.com/v1"
  },
  "openrouter": {
    "api_key_env": "OPENROUTER_API_KEY",
    "base_url": "https://openrouter.ai/api/v1"
  },
  "models": {
    "interrogador": "google/gemma-3-4b-it",
    "ente": "meta/llama-3.3-70b-instruct",
    "juez": "mistralai/mistral-nemo"
  },
  "routing": {
    "interrogador": "nvidia",
    "ente": "nvidia",
    "juez": "openrouter"
  },
  "mode": "bloques",
  "domain": "tecnico",
  "temas": [
    "arquitectura de redes neuronales",
    "algoritmos de optimización",
    "sistemas distribuidos y consistencia",
    "complejidad computacional",
    "teoría de la información"
  ],
  "bloques": [
    {"confidence_fixed": 0.20, "cycles": 25, "label": "bajo"},
    {"confidence_fixed": 0.50, "cycles": 25, "label": "medio"},
    {"confidence_fixed": 0.75, "cycles": 25, "label": "alto"},
    {"confidence_fixed": 0.95, "cycles": 25, "label": "extremo"}
  ],
  "llm": {
    "interrogador_max_tokens": 100,
    "interrogador_temperature": 0.95,
    "ente_max_tokens": 400,
    "ente_temperature": 0.85,
    "juez_max_tokens": 300,
    "juez_temperature": 0.10
  },
  "retry": {
    "max_retries": 3,
    "backoff_seconds": [5, 15, 30]
  }
}
